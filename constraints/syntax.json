{
  "schema": 1,
  "domain": "syntax",
  "language": "JavaScript",
  "engine": "Rhino",
  "ecmascriptVersion": "ES5",
  "parserValidator": "js-syntax",
  "featureValidator": "rhino-es5",
  "forbiddenFeatures": [
    "let_or_const",
    "arrow_function",
    "class",
    "async",
    "await",
    "optional_chaining",
    "nullish_coalescing",
    "spread_or_rest",
    "template_literal"
  ]
}
